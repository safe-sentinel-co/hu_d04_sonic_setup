+        rob_fwd_xy_n = rob_fwd_xy / (rob_fwd_xy.norm(dim=-1, keepdim=True) + 1e-8)
+        cos_yaw = (ref_fwd_xy_n * rob_fwd_xy_n).sum(dim=-1).clamp(-1.0, 1.0)
+        self.metrics["error_anchor_yaw"] = torch.acos(cos_yaw)
